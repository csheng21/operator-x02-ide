{
  "id": "android-support",
  "name": "Android Development Support",
  "version": "1.0.0",
  "description": "Complete Android development environment with Kotlin support and AI assistance",
  "author": "AI Code IDE",
  "category": "mobile",
  "icon": "🤖",
  "main": "./index.js",
  "activationEvents": [
    "onLanguage:kotlin",
    "onFileSystem:scheme=file",
    "workspaceContains:**/build.gradle",
    "workspaceContains:**/AndroidManifest.xml"
  ],
  "contributes": {
    "languages": [
      {
        "id": "kotlin",
        "aliases": ["Kotlin", "kt"],
        "extensions": [".kt", ".kts"],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "android.newProject",
        "title": "Create New Android Project",
        "category": "Android"
      },
      {
        "command": "android.newActivity",
        "title": "New Activity",
        "category": "Android"
      },
      {
        "command": "android.build",
        "title": "Build Project",
        "category": "Android"
      },
      {
        "command": "android.runDevice",
        "title": "Run on Device",
        "category": "Android"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .kt",
          "command": "android.newActivity",
          "group": "android"
        }
      ]
    },
    "configuration": {
      "title": "Android",
      "properties": {
        "android.sdkPath": {
          "type": "string",
          "default": "",
          "description": "Path to Android SDK"
        },
        "android.defaultMinSdk": {
          "type": "number",
          "default": 24,
          "description": "Default minimum SDK version"
        },
        "android.enableAI": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI-powered Android features"
        }
      }
    }
  },
  "engines": {
    "aicode": "^1.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^18.0.0",
    "typescript": "^4.9.0"
  }
}