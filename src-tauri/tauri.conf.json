{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OperatorX02",
  "version": "0.1.0",
  "identifier": "com.app-ai.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AI Code IDE - OperatorX02 BETA",
        "dragDropEnabled": true,
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "maximized": false,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": false,
        "center": true
      }
    ],
    "security": {
      "dangerousDisableAssetCspModification": true,
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://localhost:* http://127.0.0.1:* https: wss:; frame-src 'self' blob: http://localhost:* http://127.0.0.1:* https:; img-src 'self' data: https: blob: asset: http://asset.localhost; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src-elem 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://cdnjs.cloudflare.com; font-src 'self' data: blob: https: https://cdnjs.cloudflare.com; worker-src 'self' blob:",
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Capability for main window",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "dialog:allow-open",
            "dialog:allow-save",
            "dialog:allow-message",
            "dialog:default",
            "shell:allow-execute",
            "shell:allow-open",
            "shell:default",
            "http:default",
            "opener:default",
            "deep-link:default",
            {
              "identifier": "http:default",
              "allow": [
                { "url": "https://*.supabase.co/**" },
                { "url": "wss://*.supabase.co/**" }
              ]
            },
            {
              "identifier": "fs:allow-read-text-file",
              "allow": [
                { "path": "$HOME/**" },
                { "path": "$DESKTOP/**" },
                { "path": "$DOCUMENT/**" },
                { "path": "$DOWNLOAD/**" },
                { "path": "$APPDATA/**" },
                { "path": "$APPCONFIG/**" },
                { "path": "$APPLOG/**" },
                { "path": "$TEMP/**" },
                { "path": "**" }
              ]
            },
            {
              "identifier": "fs:allow-write-text-file",
              "allow": [
                { "path": "$HOME/**" },
                { "path": "$DESKTOP/**" },
                { "path": "$DOCUMENT/**" },
                { "path": "$DOWNLOAD/**" },
                { "path": "$APPDATA/**" },
                { "path": "$APPCONFIG/**" },
                { "path": "$APPLOG/**" },
                { "path": "$TEMP/**" },
                { "path": "**" }
              ]
            },
            {
              "identifier": "fs:allow-read-dir",
              "allow": [
                { "path": "$HOME/**" },
                { "path": "$DESKTOP/**" },
                { "path": "$DOCUMENT/**" },
                { "path": "$DOWNLOAD/**" },
                { "path": "$APPDATA/**" },
                { "path": "$APPCONFIG/**" },
                { "path": "$APPLOG/**" },
                { "path": "$TEMP/**" },
                { "path": "**" }
              ]
            },
            {
              "identifier": "fs:allow-exists",
              "allow": [
                { "path": "$HOME/**" },
                { "path": "$DESKTOP/**" },
                { "path": "$DOCUMENT/**" },
                { "path": "$DOWNLOAD/**" },
                { "path": "$APPDATA/**" },
                { "path": "$APPCONFIG/**" },
                { "path": "$APPLOG/**" },
                { "path": "$TEMP/**" },
                { "path": "**" }
              ]
            },
            {
              "identifier": "fs:allow-create",
              "allow": [
                { "path": "$HOME/**" },
                { "path": "$DESKTOP/**" },
                { "path": "$DOCUMENT/**" },
                { "path": "$DOWNLOAD/**" },
                { "path": "$APPDATA/**" },
                { "path": "$APPCONFIG/**" },
                { "path": "$APPLOG/**" },
                { "path": "$TEMP/**" },
                { "path": "**" }
              ]
            },
            {
              "identifier": "fs:allow-mkdir",
              "allow": [
                { "path": "$HOME/**" },
                { "path": "$DESKTOP/**" },
                { "path": "$DOCUMENT/**" },
                { "path": "$DOWNLOAD/**" },
                { "path": "$APPDATA/**" },
                { "path": "$APPCONFIG/**" },
                { "path": "$APPLOG/**" },
                { "path": "$TEMP/**" },
                { "path": "**" }
              ]
            },
            {
              "identifier": "fs:allow-remove",
              "allow": [
                { "path": "$HOME/**" },
                { "path": "$DESKTOP/**" },
                { "path": "$DOCUMENT/**" },
                { "path": "$DOWNLOAD/**" },
                { "path": "$APPDATA/**" },
                { "path": "$APPCONFIG/**" },
                { "path": "$APPLOG/**" },
                { "path": "$TEMP/**" },
                { "path": "**" }
              ]
            },
            "fs:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["operatorx02"]
      }
    }
  }
}
